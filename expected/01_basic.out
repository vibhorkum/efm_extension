-- Test basic extension functionality
-- Assumes extension is created as part of setup
-- Test 1: Verify schema exists
SELECT COUNT(*) AS schema_count 
FROM pg_namespace 
WHERE nspname = 'efm_extension';
 schema_count 
--------------
            1
(1 row)

-- Test 2: List all functions in the extension
SELECT proname AS function_name
FROM pg_proc p
  JOIN pg_namespace n ON p.pronamespace = n.oid
WHERE n.nspname = 'efm_extension'
  AND proname LIKE 'efm_%'
ORDER BY proname;
      function_name       
--------------------------
 efm_allow_node
 efm_cluster_status
 efm_disallow_node
 efm_failover
 efm_list_properties
 efm_resume_monitoring
 efm_set_priority
 efm_switchover
(8 rows)

-- Test 3: List all views in the extension  
SELECT viewname AS view_name
FROM pg_views
WHERE schemaname = 'efm_extension'
ORDER BY viewname;
      view_name      
---------------------
 efm_local_properties
 efm_nodes_details
(2 rows)

-- Test 4: Verify GUC parameters are registered
SELECT name, setting, unit, short_desc
FROM pg_settings
WHERE name LIKE 'efm.%'
ORDER BY name;
          name           | setting | unit |            short_desc            
-------------------------+---------+------+----------------------------------
 efm.cluster_name        |         |      | Define the cluster name for efm
 efm.command_path        |         |      | Define the command_path for efm
 efm.edb_sudo            |         |      | Define the sudo command for efm
 efm.properties_location |         |      | Define director of efm propeties file
(4 rows)

-- Test 5: Check extension metadata
SELECT extname, extversion, extrelocatable
FROM pg_extension
WHERE extname = 'efm_extension';
    extname     | extversion | extrelocatable 
----------------+------------+----------------
 efm_extension  | 1.0        | f
(1 row)

-- Test 6: Verify types exist
SELECT typname AS type_name
FROM pg_type t
  JOIN pg_namespace n ON t.typnamespace = n.oid
WHERE n.nspname = 'efm_extension'
ORDER BY typname;
       type_name        
------------------------
 pool_link_status
 pool_status
(2 rows)

